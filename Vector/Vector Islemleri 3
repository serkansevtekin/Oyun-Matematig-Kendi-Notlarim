        /*// Lerp -> İki nokta arasında doğrusal bir interpolasyon sağlar
                  -> İki değer arasında yumşak bir geçiş sağlar (0 (başlangıç) ile 1 (bitiş) arası oranla çalışır)

            Formül: a + (b - a) * t
            
            Kritik Not:
                        EĞer 0.1f gibi sabit bir değer veirrsen, her karede frame mesafesinin %10'u kadar yaklaşır. Buda hareketin doğru yavaşlamasını sağlar (Buna: "Ease-Out" denir)
        
            Lerp(Başlangıç, Hedef, Oran);
                                       -> Başlangıç (A): İşlemin başladığı mevcut değer veya konum (Örn: transform.position).
                                       -> Hedef (B): Ulaşılmak istenen son değer veya nokta (Örn: dusman.position).
                                       -> Oran (t): İki nokta arasındaki yolun yüzde kaçında olduğun (0 ile 1 arası değer).
                                       -> Time.deltaTime: Oranla çarpıldığında, geçişi kare hızından (FPS) bağımsız ve akıcı yapar.
   
   
   
   1- Örnek Kullanım:
     public Transform _Obj1;  // Hedef obje
    public float targetTime; // hedef süre
    private float elapsedTime; // Geçen süre
    private Vector3 startPos; // Başlangıç pozisyonu

    void Start()
    {
        startPos = transform.position; // Oyun başladığında bulunduğumuz konumu bir vektör olarak kaydediyoruz
        Debug.Log(startPos);
    }
    
    void Update()
    {
          // elapsedTime (Geçen Süre) hedeflediğimiz süreden küçük olduğu sürece çalış:
        if (elapsedTime < targetTime)
        {
            // Her karede geçen süreyi üzerine ekle (Kronometre gibi)
            elapsedTime += Time.deltaTime;

            // Yüzde hesabı: Geçen Süre / Hedef Süre (0 ile 1 arası bir değer üretir)
            float percentage = elapsedTime / targetTime;

            // Start'ta kaydettiğimiz noktadan, hedefe, yüzdeye göre kaydır.
            transform.position = Vector3.Lerp(startPos, _Obj1.position, percentage);
        }

     
    }

