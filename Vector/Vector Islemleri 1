using UnityEngine;

public class Vector_Islemleri_1 : MonoBehaviour
{
    // Vector2 -> x, y
    // Vector3 -> x, y, z
    // Vector4 -> x, y, z, w

    // Vector3 tanımlama
    Vector3 _Pozisyon;

    public Vector3 _DisaridanPozisyonum;

    public float x, y, z;

    void Start()
    {
        // Yeni bir vector3 pozisyon oluşturma
        _Pozisyon = new Vector3(4.2f,3.6f,1.2f);

        // Dışarıdan ayrı ayrı girilen x, y, z değerlerini Vector3'e verme ve o değerlerle yeni pozisyon oluşturma
        _Pozisyon = new Vector3(x,y,z);
   

        // Scriptin bağlı olduğu GameObje'nin pozisyonunu almak için

        // Objenin kendi pozisyonunu bir Vector3 değişkenine aktarma
        _Pozisyon = transform.position; // Vector3 türünde dünya kordinartlarına göre pozisyon değeri verir

        // Objenin pozisyonuna yeni bir pozisyon verme
        transform.position = new Vector3(2f,3f,5f);

        // Inspectordan girilen bir pozisyonu objenin pozisyopnuna verme
        transform.position = _DisaridanPozisyonum;


        // Objenin Mevcut pozisyonun koru ve diğerlerini değiştir [Not: Bu diğer kordinat ekesenleri içinde aynı şekilde geçerli]
        transform.position = new Vector3(transform.position.x,y,z);
        transform.position = new Vector3(x,transform.position.y,z);
        transform.position = new Vector3(x,y,transform.position.z);


        // Objenin mevcut sahip olduğu pozisyonu üzerine Yeni Pozisyon ekle
        // Uzun yol
        transform.position = new Vector3(transform.position.x + x, transform.position.y + y, transform.position.z + z);

        // Kısa yol [+=]
        transform.position += new Vector3(x,y,z);




        // !!!!!!!!!!! KESİNLİK İLE YAPILAMAZ OLAN !!!!!!!!!
        // transform.position.x = 40;
        // transform.position.y = 4;
        // transform.position.z = 14;



    }
}
